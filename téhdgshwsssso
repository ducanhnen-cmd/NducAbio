    iconLabel.TextSize = 20
    iconLabel.TextColor3 = Color3.fromRGB(0, 150, 255)
    iconLabel.Font = Enum.Font.Gotham
    iconLabel.Parent = btn
    
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, -90, 1, 0)
    textLabel.Position = UDim2.new(0, 45, 0, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.Text = text
    textLabel.TextColor3 = Color3.fromRGB(220, 220, 220)
    textLabel.TextSize = 13
    textLabel.Font = Enum.Font.GothamSemibold
    textLabel.TextXAlignment = Enum.TextXAlignment.Left
    textLabel.Parent = btn
    
    local status = Instance.new("TextLabel")
    status.Size = UDim2.new(0, 50, 1, 0)
    status.Position = UDim2.new(1, -55, 0, 0)
    status.BackgroundTransparency = 1
    status.Text = "OFF"
    status.TextColor3 = Color3.fromRGB(255, 80, 80)
    status.TextSize = 12
    status.Font = Enum.Font.GothamBold
    status.Parent = btn
    
    local enabled = false
    
    btn.MouseButton1Click:Connect(function()
        enabled = not enabled
        if enabled then
            status.Text = "ON"
            status.TextColor3 = Color3.fromRGB(0, 255, 100)
            btn.BackgroundColor3 = Color3.fromRGB(45, 45, 55)
        else
            status.Text = "OFF"
            status.TextColor3 = Color3.fromRGB(255, 80, 80)
            btn.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
        end
        if callback then callback(enabled) end
    end)
    
    return btn
end

-- ========== HÀM LẤY LEVEL NGƯỜI CHƠI ==========
local function getPlayerLevel()
    local player = Players.LocalPlayer
    local leaderstats = player:FindFirstChild("leaderstats")
    if leaderstats then
        local level = leaderstats:FindFirstChild("Level")
        if level then return level.Value end
    end
    return 1
end

-- ========== HÀM TÌM ĐẢO THEO LEVEL ==========
local function getIslandByLevel(level)
    for _, island in ipairs(islands) do
        if level >= island.MinLevel and level <= island.MaxLevel then
            return island
        end
    end
    return islands[#islands]
end

-- ========== HÀM TELEPORT ==========
local function teleportToPos(position)
    local player = Players.LocalPlayer
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        char.HumanoidRootPart.CFrame = CFrame.new(position)
    end
end

-- ========== FARM LEVEL TỰ ĐỘNG ==========
local function startFarmLevel()
    task.spawn(function()
        while farmLevelEnabled do
            local player = Players.LocalPlayer
            local char = player.Character
            if not char then task.wait(1) continue end
            
            local root = char:FindFirstChild("HumanoidRootPart")
            if not root then task.wait(1) continue end
            
            local currentLevel = getPlayerLevel()
            local newIsland = getIslandByLevel(currentLevel)
            
            if newIsland and (not currentIslandTarget or newIsland.Name ~= currentIslandTarget.Name) then
                currentIslandTarget = newIsland
                print("[Farm Level] Đang di chuyển đến:", currentIslandTarget.Name, "| Level:", currentLevel)
                teleportToPos(currentIslandTarget.Pos)
                task.wait(2)
            end
            
            task.wait(1)
        end
    end)
end

-- ========== FAST ATTACK ==========
local function startFastAttack()
    task.spawn(function()
        while fastAttackEnabled do
            task.wait()
            local player = Players.LocalPlayer
            local char = player.Character
            if not char then continue end
            local root = char:FindFirstChild("HumanoidRootPart")
            if not root then continue end
            
            local enemies = Workspace:FindFirstChild("Enemies")
            if enemies then
                for _, m in ipairs(enemies:GetChildren()) do
                    local hrp = m:FindFirstChild("HumanoidRootPart")
                    local hum = m:FindFirstChild("Humanoid")
                    if hrp and hum and hum.Health > 0 and (hrp.Position - root.Position).Magnitude <= 150 then
                        pcall(function()
                            local RS = ReplicatedStorage
                            if RS and RS.Modules and RS.Modules.Net then
                                local atk = RS.Modules.Net["RE/RegisterAttack"]
                                if atk then atk:FireServer() end
                            end
                        end)
                        break
                    end
                end
            end
        end
    end)
end

-- ========== BRING MOB (KÉO QUÁI) ==========
local function startBringMob()
    task.spawn(function()
        while bringMobEnabled do
            task.wait(0.15)
            local player = Players.LocalPlayer
            local char = player.Character
            if not char then task.wait(1) continue end
            local root = char:FindFirstChild("HumanoidRootPart")
            if not root then continue end
            
            local rootPos = root.Position
            local lookVector = root.CFrame.LookVector
            
            for _, v in ipairs(Workspace:GetDescendants()) do
                if v:IsA("Model") and v:FindFirstChild("HumanoidRootPart") and v:FindFirstChild("Humanoid") then
                    local hrp = v.HumanoidRootPart
                    local hum = v.Humanoid
                    
                    if not Players:GetPlayerFromCharacter(v) and hum.Health > 0 then
                        local dist = (hrp.Position - rootPos).Magnitude
                        if dist <= 100 then
                            local targetPos = rootPos + lookVector * 5
                            hrp.CFrame = hrp.CFrame:Lerp(CFrame.new(targetPos), 0.6)
                        end
                    end
                end
            end
        end
    end)
end

-- ========== FIX LAG ==========
local function applyFixLag()
    if not fixLagEnabled then return end
    pcall(function()
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 1000
        local settings = UserSettings()
        local gameSettings = settings:GetService("UserGameSettings")
        gameSettings.EnvironmentalQuality = Enum.EnvironmentalQuality.Low
    end)
end

local function startFixLagLoop()
    task.spawn(function()
        while fixLagEnabled do
            applyFixLag()
            task.wait(5)
        end
    end)
end

-- ========== FARM XƯƠNG (HAUNTED CASTLE) ==========
local function startFarmBone()
    task.spawn(function()
        while farmBoneEnabled do
            local player = Players.LocalPlayer
            local char = player.Character
            if not char then task.wait(1) continue end
            
            local root = char:FindFirstChild("HumanoidRootPart")
            if not root then task.wait(1) continue end
            
            -- Teleport đến Haunted Castle
            if (root.Position - hauntedCastlePos).Magnitude > 500 then
                teleportToPos(hauntedCastlePos)
                task.wait(2)
            end
            
            -- Tìm và tấn công quái
