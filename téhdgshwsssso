-- ========== FARM TYRANT OF THE SKIES (TIKI OUTPOST) ==========
local tyrantKillCount = 0
local tyrantRequiredKills = 300
local eyesGlowing = {false, false, false, false}
local isBossFighting = false
local bossSpawned = false

local function checkTyrantStatues()
    -- Kiểm tra tượng đại bàng và mắt đã sáng chưa
    local statueLeft = Workspace:FindFirstChild("EagleStatueLeft")
    local statueRight = Workspace:FindFirstChild("EagleStatueRight")
    
    if statueLeft and statueRight then
        -- Kiểm tra mắt (cần tìm đúng attribute)
        for i = 1, 2 do
            local eye = statueLeft:FindFirstChild("Eye" .. i)
            if eye and eye:GetAttribute("Glowing") then
                eyesGlowing[i] = true
            end
        end
        for i = 1, 2 do
            local eye = statueRight:FindFirstChild("Eye" .. i)
            if eye and eye:GetAttribute("Glowing") then
                eyesGlowing[i+2] = true
            end
        end
    end
    
    -- Đếm số mắt đã sáng
    local glowingCount = 0
    for _, v in ipairs(eyesGlowing) do
        if v then glowingCount = glowingCount + 1 end
    end
    
    return glowingCount
end

local function breakTyrantVases()
    -- Đập vỡ bình gốm xung quanh khu vực tượng
    local vases = Workspace:FindFirstChild("BreakableVases") or Workspace:FindFirstChild("Vases")
    if vases then
        for _, vase in ipairs(vases:GetChildren()) do
            if vase:IsA("BasePart") and vase.Visible then
                local player = Players.LocalPlayer
                local char = player.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    char.HumanoidRootPart.CFrame = vase.CFrame
                    task.wait(0.1)
                    
                    -- Dùng skill để đập bình (nếu có Buddha)
                    if fastAttackEnabled then
                        pcall(function()
                            local RS = ReplicatedStorage
                            if RS and RS.Modules and RS.Modules.Net then
                                local atk = RS.Modules.Net["RE/RegisterAttack"]
                                if atk then atk:FireServer() end
                            end
                        end)
                    end
                end
            end
        end
        return true
    end
    return false
end

local function findTyrantBoss()
    -- Tìm boss Tyrant of the Skies
    for _, v in ipairs(Workspace:GetDescendants()) do
        if v:IsA("Model") and (v.Name == "Tyrant of the Skies" or string.find(v.Name, "Tyrant") or string.find(v.Name, "Skies")) then
            return v
        end
    end
    return nil
end

local function fightTyrantBoss()
    local boss = findTyrantBoss()
    if not boss then return false end
    
    local hrp = boss:FindFirstChild("HumanoidRootPart")
    local hum = boss:FindFirstChild("Humanoid")
    
    if hrp and hum and hum.Health > 0 then
        local player = Players.LocalPlayer
        local char = player.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            local root = char.HumanoidRootPart
            -- Teleport đến gần boss (boss bay trên không)
            root.CFrame = hrp.CFrame * CFrame.new(0, 10, 15)
            task.wait(0.1)
            
            if fastAttackEnabled then
                pcall(function()
                    local RS = ReplicatedStorage
                    if RS and RS.Modules and RS.Modules.Net then
                        local atk = RS.Modules.Net["RE/RegisterAttack"]
                        if atk then atk:FireServer() end
                    end
                end)
            end
        end
        return true
    end
    return false
end

local function startFarmTyrant()
    task.spawn(function()
        while farmTyrantEnabled do
            local player = Players.LocalPlayer
            local char = player.Character
            if not char then task.wait(1) continue end
            
            local root = char:FindFirstChild("HumanoidRootPart")
            if not root then task.wait(1) continue end
            
            -- 1. Teleport đến Tiki Outpost
            if (root.Position - tikiOutpostPos).Magnitude > 500 then
                print("[Tyrant] Đang di chuyển đến Tiki Outpost...")
                teleportToPos(tikiOutpostPos)
                task.wait(2)
            end
            
            -- 2. Kiểm tra boss đã spawn chưa
            local boss = findTyrantBoss()
            if boss then
                if not isBossFighting then
                    print("[Tyrant] Boss đã xuất hiện! Đang chiến đấu...")
                    isBossFighting = true
                end
                if not fightTyrantBoss() then
                    -- Boss đã chết
                    isBossFighting = false
                    print("[Tyrant] Đã đánh bại Tyrant of the Skies!")
                    tyrantKillCount = 0
                end
                task.wait(0.3)
                continue
            end
            
            isBossFighting = false
            
            -- 3. Kiểm tra trạng thái mắt tượng
            local glowingEyes = checkTyrantStatues()
            
            -- 4. Nếu chưa đủ 4 mắt sáng, farm quái
            if glowingEyes < 4 then
                -- Farm quái ở Tiki Outpost
                local enemies = Workspace:FindFirstChild("Enemies")
                local targetNPC = nil
                
                if enemies then
                    for _, npc in ipairs(enemies:GetChildren()) do
                        for _, tikiNPC in ipairs(tikiNPCs) do
                            if string.find(npc.Name, tikiNPC) then
                                local hum = npc:FindFirstChild("Humanoid")
                                local hrp = npc:FindFirstChild("HumanoidRootPart")
                                if hum and hrp and hum.Health > 0 then
                                    targetNPC = npc
                                    break
                                end
                            end
                        end
                        if targetNPC then break end
                    end
                end
                
                if targetNPC then
                    local hrp = targetNPC:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        root.CFrame = hrp.CFrame * CFrame.new(0, 0, 10)
                        task.wait(0.1)
                        
                        if fastAttackEnabled then
                            pcall(function()
                                local RS = ReplicatedStorage
                                if RS and RS.Modules and RS.Modules.Net then
                                    local atk = RS.Modules.Net["RE/RegisterAttack"]
                                    if atk then atk:FireServer() end
                                end
                            end)
                        end
                        tyrantKillCount = tyrantKillCount + 1
                        if tyrantKillCount % 10 == 0 then
                            print("[Tyrant] Đã tiêu diệt:", tyrantKillCount, "/", tyrantRequiredKills, "quái")
                        end
                    end
                else
                    -- Di chuyển quanh đảo
                    local wanderPos = tikiOutpostPos + Vector3.new(math.random(-80, 80), 0, math.random(-80, 80))
                    teleportToPos(wanderPos)
                    task.wait(2)
                end
            else
                -- 5. Đã đủ 4 mắt sáng, đập bình để triệu hồi boss
                print("[Tyrant] Đã đủ 300 quái! Đang đập bình để triệu hồi boss...")
                breakTyrantVases()
                task.wait(1)
            end
            
            task.wait(0.3)
        end
    end)
end

